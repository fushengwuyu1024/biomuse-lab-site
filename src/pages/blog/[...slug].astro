---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingDate } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";
import { SITE, SOCIALS } from "@consts";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();
---

<PageLayout title={post.data.title} description={post.data.description}>
  <Container>
   <div class="animate flex gap-2">
      <a href="/" class="relative group w-fit flex items-center gap-1.5 px-3 py-1.5 rounded border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300 ease-in-out text-black dark:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform duration-300 ease-in-out">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
        <span class="text-sm">返回主页</span>
      </a>

      <BackToPrev href="/blog">
        Back to blog
      </BackToPrev>
    </div>
    <div class="space-y-1 my-10 text-stone-600 dark:text-stone-400">
      <div class="animate flex items-center gap-1.5">
        <FormattedDate date={post.data.date} />
      </div>
      <div class="animate text-2xl font-semibold text-black dark:text-white">
        {post.data.title}
      </div>
    </div>
    <article class="animate">
      <Content />

      <div class="animate flex flex-wrap gap-x-4 gap-y-2 mt-4 mb-6">
        {post.data.tags && post.data.tags.map((tag: string) => (
          <span class="text-stone-500 dark:text-stone-400 text-sm hover:text-black dark:hover:text-white transition-colors cursor-default">
            #{tag}
          </span>
        ))}
      </div>
      <div class="animate flex items-center justify-start gap-6 mt-6 mb-10 text-stone-500 dark:text-stone-400">
       <button class="like-btn group flex items-center gap-1.5 hover:text-rose-500 transition-colors duration-300">
         <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform">
           <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
         </svg>
         <span class="text-sm">喜欢</span>
       </button>

       <span class="text-stone-300 dark:text-stone-800">|</span>

       <button class="comment-btn group flex items-center gap-1.5 hover:text-blue-500 transition-colors duration-300">
         <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform">
           <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
         </svg>
         <span class="text-sm">评论</span>
       </button>

       <span class="text-stone-300 dark:text-stone-800">|</span>

       <button class="share-btn group flex items-center gap-1.5 hover:text-emerald-500 transition-colors duration-300">
         <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform">
           <circle cx="18" cy="5" r="3"></circle>
           <circle cx="6" cy="12" r="3"></circle>
           <circle cx="18" cy="19" r="3"></circle>
           <line x1="8.59" y1="13.51" x2="15.42" y1="17.49"></line>
           <line x1="15.41" y1="6.51" x2="8.59" y1="10.49"></line>
         </svg>
         <span class="text-sm">转发</span>
       </button>
     </div>

     <div class="animate mt-12">
        <script src="https://giscus.app/client.js"
                data-repo="fushengwuyu1024/biomuse-lab-site"
                data-repo-id="R_kgDORqTUtw"
                data-category="Announcements"
                data-category-id="DIC_kwDORqTUt84C5Aga"
                data-mapping="pathname"
                data-strict="0"
                data-reactions-enabled="1"
                data-emit-metadata="0"
                data-input-position="bottom"
                data-theme="preferred_color_scheme"
                data-lang="zh-CN"
                crossorigin="anonymous"
                async>
        </script>
      </div>

      <hr class="my-12 border-stone-200 dark:border-stone-800" />
      <section class="space-y-6 pb-20">
        <h5 class="font-semibold text-black dark:text-white text-lg">
          让我们彼此触达
        </h5>
        <div class="prose dark:prose-invert text-stone-600 dark:text-stone-400">
          <p>
            万物穿身而过，就在此处。如果你想知道更多，或者想和我聊聊任何想法，或者单纯打个招呼，欢迎通过以下方式触达。（点击下方可跳转）
          </p>
        </div>
        <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
          {SOCIALS.map((SOCIAL) => (
            <li class="flex items-center gap-x-4">
              <a href={SOCIAL.HREF} target="_blank" class="underline underline-offset-4 decoration-stone-300 dark:decoration-stone-700 hover:decoration-black dark:hover:decoration-white transition-all">
                {SOCIAL.NAME}
              </a>
              <span class="text-stone-300 dark:text-stone-800">/</span>
            </li>
          ))}
          <li>
            <a href={`mailto:${SITE.EMAIL}`} class="underline underline-offset-4 decoration-stone-300 dark:decoration-stone-700 hover:decoration-black dark:hover:decoration-white transition-all">
              {SITE.EMAIL}
            </a>
          </li>
        </ul>
      </section>
    </article>
  </Container>
</PageLayout>

<script is:inline>
  // 1. 填入你的 Supabase 凭证
  const SUPABASE_URL = 'https://qernpndylyidpkkxapvc.supabase.co';
  const SUPABASE_KEY = '这里粘贴你刚才复制的 Publishable key (sb_publishable_...)';
  
  // 获取当前文章路径 (去除末尾斜杠)
  const postSlug = window.location.pathname.replace(/\/$/, ""); 

  document.addEventListener('astro:page-load', async () => {
    const likeBtn = document.querySelector('.like-btn');
    const likeText = likeBtn?.querySelector('span');
    const heartIcon = likeBtn?.querySelector('svg');
    const commentBtn = document.querySelector('.comment-btn');
    const shareBtn = document.querySelector('.share-btn');

    if (!likeBtn) return;

    // --- 逻辑 A: 获取初始点赞数 ---
    async function getInitialLikes() {
      try {
        const response = await fetch(`${SUPABASE_URL}/rest/v1/post_stats?slug=eq.${postSlug}&select=likes`, {
          headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` }
        });
        const data = await response.json();
        
        if (data.length > 0) {
          likeText.innerText = `${data[0].likes} 喜欢`;
        } else {
          // 初始化记录
          await fetch(`${SUPABASE_URL}/rest/v1/post_stats`, {
            method: 'POST',
            headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug: postSlug, likes: 0 })
          });
          likeText.innerText = `0 喜欢`;
        }
      } catch (e) { console.error("Database error:", e); }
    }

    getInitialLikes();

    // --- 逻辑 B: 点击增加点赞 ---
    likeBtn.addEventListener('click', async () => {
      heartIcon.setAttribute('fill', '#f43f5e');
      heartIcon.setAttribute('stroke', '#f43f5e');
      heartIcon.classList.add('scale-125');
      setTimeout(() => heartIcon.classList.remove('scale-125'), 200);

      const currentVal = parseInt(likeText.innerText) || 0;
      const newVal = currentVal + 1;

      await fetch(`${SUPABASE_URL}/rest/v1/post_stats?slug=eq.${postSlug}`, {
        method: 'PATCH',
        headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ likes: newVal })
      });
      likeText.innerText = `${newVal} 喜欢`;
    }, { once: true }); // 防止疯狂刷票

    // --- 逻辑 C: 评论与转发功能 ---
    commentBtn?.addEventListener('click', () => {
      document.querySelector('.giscus')?.scrollIntoView({ behavior: 'smooth' });
    });

    shareBtn?.addEventListener('click', () => {
      if (navigator.share) {
        navigator.share({ title: document.title, url: window.location.href });
      } else {
        navigator.clipboard.writeText(window.location.href);
        alert('链接已复制到剪贴板');
      }
    });
  });
</script>
