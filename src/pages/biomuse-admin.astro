---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
---

<PageLayout title="控制台 | BioMuse_Lab" description="主理人专属权限">
  <Container>
    <div class="py-24 max-w-xl mx-auto space-y-12">
      
      <header class="space-y-3 text-center">
        <h1 class="text-3xl font-bold tracking-tight text-black dark:text-white">上帝控制台</h1>
        <p class="text-stone-500 text-sm italic font-serif">“在这里，数据只是可塑的黏土。”</p>
      </header>

      <div id="auth-section" class="p-8 border border-stone-200 dark:border-stone-800 rounded-xl bg-stone-50/50 dark:bg-stone-900/50 backdrop-blur-sm space-y-6">
        <div class="space-y-2">
          <label class="text-xs uppercase tracking-widest text-stone-400 font-semibold">验证密钥</label>
          <input type="password" id="admin-pass" placeholder="••••••••" class="w-full px-4 py-3 rounded-lg border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-800 focus:outline-none focus:ring-2 focus:ring-black dark:focus:ring-white transition-all text-center tracking-widest" />
        </div>
        <button id="login-btn" class="w-full py-3 bg-black dark:bg-white text-white dark:text-black rounded-lg font-medium hover:opacity-90 transition-all active:scale-[0.98]">进入后台</button>
      </div>

      <div id="control-section" class="hidden animate-in fade-in slide-in-from-bottom-4 duration-700 space-y-6">
        <div class="p-8 border border-stone-200 dark:border-stone-800 rounded-xl space-y-8">
          
          <div class="space-y-2">
            <label class="text-xs uppercase tracking-widest text-stone-400 font-semibold">目标文章路径 (Slug)</label>
            <input type="text" id="target-slug" placeholder="/blog/qiangpo" class="w-full px-4 py-2 bg-stone-50 dark:bg-stone-900 rounded-md border border-stone-200 dark:border-stone-800 focus:ring-1 focus:ring-stone-400 outline-none" />
          </div>

          <div class="grid grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-xs uppercase tracking-widest text-stone-400 font-semibold">喜欢 (Likes)</label>
              <input type="number" id="new-likes" placeholder="0" class="w-full px-4 py-2 bg-stone-50 dark:bg-stone-900 rounded-md border border-stone-200 dark:border-stone-800" />
            </div>
            <div class="space-y-2">
              <label class="text-xs uppercase tracking-widest text-stone-400 font-semibold">阅读 (Views)</label>
              <input type="number" id="new-views" placeholder="0" class="w-full px-4 py-2 bg-stone-50 dark:bg-stone-900 rounded-md border border-stone-200 dark:border-stone-800" />
            </div>
          </div>

          <button id="update-btn" class="w-full py-4 bg-rose-600 text-white rounded-lg font-bold hover:bg-rose-500 shadow-lg shadow-rose-500/20 transition-all active:scale-[0.98]">重塑数据</button>
          
          <p id="status-msg" class="text-center text-sm font-medium h-4 text-stone-500"></p>
        </div>
      </div>

    </div>
  </Container>
</PageLayout>

<script is:inline>
  const SUPABASE_URL = 'https://qernpndylyidpkkxapvc.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_MS5LLXfj-dri8s3OuzEtpQ_Y-6Q0I38';
  const ADMIN_KEY = 'insight2026';

  document.addEventListener('astro:page-load', () => {
    const authSection = document.getElementById('auth-section');
    const controlSection = document.getElementById('control-section');
    const loginBtn = document.getElementById('login-btn');
    const adminPass = document.getElementById('admin-pass');
    
    const updateBtn = document.getElementById('update-btn');
    const statusMsg = document.getElementById('status-msg');

    loginBtn.onclick = () => {
      if (adminPass.value === ADMIN_KEY) {
        authSection.style.display = 'none';
        controlSection.classList.remove('hidden');
      } else {
        alert('密钥错误，权限拒绝');
      }
    };

    updateBtn.onclick = async () => {
      const slug = document.getElementById('target-slug').value;
      const likes = parseInt(document.getElementById('new-likes').value);
      const views = parseInt(document.getElementById('new-views').value);

      if (!slug) return alert('请输入 Slug');

      statusMsg.innerText = '正在入侵数据库...';

      try {
        const response = await fetch(`${SUPABASE_URL}/rest/v1/post_stats?slug=eq.${slug}`, {
          method: 'PATCH',
          headers: {
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${SUPABASE_KEY}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ likes, views })
        });

        if (response.ok) {
          statusMsg.innerText = '✨ 世界已重塑。';
          setTimeout(() => statusMsg.innerText = '', 3000);
        } else {
          statusMsg.innerText = '❌ 路径不存在，请检查 Slug';
        }
      } catch (e) {
        statusMsg.innerText = '📡 连接中断';
      }
    };
  });
</script>
