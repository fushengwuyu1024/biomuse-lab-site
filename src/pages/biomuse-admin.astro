---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
---

<PageLayout title="控制台 | BioMuse_Lab" description="主理人专属权限">
  <Container>
    <div class="animate mt-20 space-y-10">
      <header class="space-y-2">
        <h1 class="text-3xl font-semibold text-black dark:text-white">上帝控制台</h1>
        <p class="text-stone-500 text-sm italic">“在这里，数据只是可塑的黏土。”</p>
      </header>

      <div id="auth-section" class="space-y-4">
        <input type="password" id="admin-pass" placeholder="输入访问密钥..." class="w-full px-4 py-2 rounded border border-stone-200 dark:border-stone-800 bg-transparent focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white transition-all" />
        <button id="login-btn" class="px-6 py-2 bg-black dark:bg-white text-white dark:text-black rounded text-sm hover:opacity-80 transition-opacity">进入后台</button>
      </div>

      <div id="control-section" class="hidden space-y-8 pb-20">
        <div class="p-6 border border-stone-200 dark:border-stone-800 rounded-lg space-y-6">
          <div class="space-y-2">
            <label class="text-sm font-medium">目标文章 Slug</label>
            <input type="text" id="target-slug" placeholder="例如: /blog/qiangpo" class="w-full px-3 py-1.5 bg-stone-50 dark:bg-stone-900 rounded border border-stone-200 dark:border-stone-800" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-2">
              <label class="text-sm font-medium">点赞数 (Likes)</label>
              <input type="number" id="new-likes" class="w-full px-3 py-1.5 bg-stone-50 dark:bg-stone-900 rounded border border-stone-200 dark:border-stone-800" />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-medium">阅读量 (Views)</label>
              <input type="number" id="new-views" class="w-full px-3 py-1.5 bg-stone-50 dark:bg-stone-900 rounded border border-stone-200 dark:border-stone-800" />
            </div>
          </div>

          <button id="update-btn" class="w-full py-2 bg-rose-500 text-white rounded text-sm font-semibold hover:bg-rose-600 transition-colors">执行修改</button>
          <p id="status-msg" class="text-center text-xs text-stone-400"></p>
        </div>
      </div>
    </div>
  </Container>
</PageLayout>

<script is:inline>
  const SUPABASE_URL = 'https://qernpndylyidpkkxapvc.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_MS5LLXfj-dri8s3OuzEtpQ_Y-6Q0I38';
  const ADMIN_KEY = 'insight2026'; // 这是你的登录密码，你可以自己改

  document.addEventListener('astro:page-load', () => {
    const authSection = document.getElementById('auth-section');
    const controlSection = document.getElementById('control-section');
    const loginBtn = document.getElementById('login-btn');
    const adminPass = document.getElementById('admin-pass');
    
    const updateBtn = document.getElementById('update-btn');
    const statusMsg = document.getElementById('status-msg');

    // 1. 简易登录逻辑
    loginBtn.onclick = () => {
      if (adminPass.value === ADMIN_KEY) {
        authSection.classList.add('hidden');
        controlSection.classList.remove('hidden');
      } else {
        alert('密钥错误');
      }
    };

    // 2. 数据更新逻辑
    updateBtn.onclick = async () => {
      const slug = document.getElementById('target-slug').value;
      const likes = parseInt(document.getElementById('new-likes').value);
      const views = parseInt(document.getElementById('new-views').value);

      if (!slug) return alert('请输入 Slug');

      statusMsg.innerText = '正在入侵数据库...';

      try {
        const response = await fetch(`${SUPABASE_URL}/rest/v1/post_stats?slug=eq.${slug}`, {
          method: 'PATCH',
          headers: {
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${SUPABASE_KEY}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ likes, views })
        });

        if (response.ok) {
          statusMsg.innerText = '修改成功，世界已重塑。';
          setTimeout(() => statusMsg.innerText = '', 3000);
        } else {
          statusMsg.innerText = '修改失败，请检查 Slug 是否正确。';
        }
      } catch (e) {
        statusMsg.innerText = '连接中断。';
      }
    };
  });
</script>
