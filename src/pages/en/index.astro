---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { SITE } from "@consts";
---

<PageLayout title="BioMuse Lab | EN" description="Digital Fortress of an Unshaped Woman">
  <Container>
    <div class="space-y-16">
      
      <section>
        <article class="space-y-4">
          <h4 class="animate font-semibold text-black dark:text-white">
            Right Here, Just as I am 👋🏻
          </h4>
          <p class="animate">
            An unshaped woman, currently exploring within a biotech company in Shanghai.
          </p>
          <p class="animate">
            Viewing the entire life journey as a creative work, maintaining a state of continuous flow. Writing what is writable in text, being sincere and authentic in podcasts, and documenting professional insights and research methodologies in the field of Life Sciences.
          </p>
          <p class="animate">
            Building a "Resonance Lab" that connects <strong>"Emotional Creation"</strong> with <strong>"Rational Experimentation."</strong>
          </p>
          <p class="animate">
            <em>"As all things pass through me, I gather them into my vessel."</em> Writing, research, and art are all interconnected forms of expression—the continuous traces of life flowing within this vessel. Welcome to my digital fortress; let us explore the wonders of this world together.
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 justify-between items-center">
          <h5 class="font-semibold text-black dark:text-white">Recent Posts</h5>
          <a href="/blog" class="text-sm border-b border-black/20 dark:border-white/20">See all</a>
        </div>
        <p class="text-sm italic text-black/50 dark:text-white/50">English versions are currently being synchronized...</p>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 justify-between items-center">
          <h5 class="font-semibold text-black dark:text-white">Professional Experience</h5>
        </div>
        <div class="space-y-8">
          <div>
            <div class="text-sm text-black/50 dark:text-white/50">Jul 2024 - Mar 2026</div>
            <div class="font-semibold">Bioligo (Shanghai)</div>
            <div class="text-sm">Scientific Sales</div>
            <ul class="mt-2 list-disc list-inside text-sm space-y-1">
              <li>Engaging with universities, research institutes, and hospitals to explore and meet client needs.</li>
              <li>Leveraging graduate background to manage and expand client resources through alumni networks.</li>
              <li>Connecting with PIs, doctoral students, and medical professionals.</li>
              <li>Liaising between Business, Marketing, Synthesis, R&D, and Logistics departments.</li>
              <li>Emphasizing autonomy, self-driven growth, and anti-fragility.</li>
            </ul>
          </div>
          <div>
            <div class="text-sm text-black/50 dark:text-white/50">Sep 2021 - Jul 2024</div>
            <div class="font-semibold">East China University of Science and Technology (ECUST)</div>
            <div class="text-sm">Graduate Student</div>
            <ul class="mt-2 list-disc list-inside text-sm space-y-1">
              <li>School of Pharmacy. Research focus: Integration of CAR-T therapy and microfluidic chips.</li>
              <li>Maintained a strong personal identity within the domestic research system.</li>
              <li>Evaluated by mentors as having "active thinking and unique ideas."</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 justify-between items-center">
          <h5 class="font-semibold text-black dark:text-white">Inspired Works</h5>
          <a href="/projects" class="text-sm border-b border-black/20 dark:border-white/20">See all</a>
        </div>
        <p class="text-sm italic text-black/50 dark:text-white/50">Creative projects are being migrated...</p>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">Reach Out</h5>
        <p class="text-sm">If you want to know more, or simply say hi, feel free to reach me via:</p>
        <div class="flex gap-2 text-sm border-b border-black/10 dark:border-white/10 pb-4">
          <a href="#">WeChat Official Account</a> / <a href="#">Podcast</a> / <a href="#">Website</a> / <a href="mailto:rightheretc@163.com">rightheretc@163.com</a>
        </div>
      </section>

    </div>
  </Container>
</PageLayout>
