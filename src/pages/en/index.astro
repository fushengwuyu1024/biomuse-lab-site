---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { SITE } from "@consts";
---

<PageLayout title="BioMuse Lab | English" description="A bridge between industrial research and scientific innovation.">
  <Container>
    <div class="space-y-10">
      <section>
        <article class="space-y-4">
          <h4 class="animate font-semibold text-black dark:text-white">
            BioMuse Lab: Bridging Industry & Research
          </h4>
          <p class="animate text-sm text-black/60 dark:text-white/60">
            Welcome. I am a Pharmaceutical researcher (ECUST) currently active in the biotech industry at Bioligo, Shanghai.
          </p>
          <p class="animate">
            My expertise lies at the intersection of <strong>Nucleic Acid Technology</strong> and <strong>CAR-T Cell Therapy</strong>. This space serves as my digital repository for professional insights, research methodologies, and artistic inspirations.
          </p>
          <p class="animate border-l-2 border-black/10 dark:border-white/10 pl-4 italic text-black/70 dark:text-white/70">
            "Science is the rigorous experiment; Art is the spiritual escape."
          </p>
          <p class="animate">
            Looking ahead to 2027, I am preparing for my doctoral journey in Europe (Germany/Nordic), aiming to explore the synergy between high-level laboratory research and international business development.
          </p>
        </article>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          Mission
        </h5>
        <p class="text-sm">
          To build a "Resonance Lab" connecting emotional creation with rational experimentation. 
          I am currently translating my key insights into English, focusing on technical observations from the Chinese biotech sector.
        </p>
      </section>
    </div>
  </Container>
</PageLayout>
