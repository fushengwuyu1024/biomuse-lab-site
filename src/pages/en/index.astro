---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { SITE } from "@consts";

const posts = (await getCollection("blog"))
  .filter(post => !post.data.draft && post.data.lang === "en") 
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<PageLayout title="BioMuse Lab | EN" description="Digital Fortress of an Unshaped Woman">
  <Container>
    <div class="space-y-16">
      
      <section>
        <article class="space-y-4">
          <h4 class="animate font-semibold text-black dark:text-white">
            Right Here, Just as I am 👋🏻
          </h4>
          <p class="animate">
            An unshaped woman, currently exploring within a biotech company in Shanghai.
          </p>
          <p class="animate">
            Viewing the entire life journey as a creative work, maintaining a state of continuous flow. Writing what is writable in text, being sincere and authentic in podcasts, and documenting professional insights and research methodologies in the field of Life Sciences.
          </p>
          <p class="animate">
            Building a "Resonance Lab" that connects <strong>"Emotional Creation"</strong> with <strong>"Rational Experimentation."</strong>
          </p>
          <p class="animate border-l-2 border-black/10 dark:border-white/10 pl-4">
            <em>"As all things pass through me, I gather them into my vessel."</em> <br/>
            Writing, research, and art are all interconnected forms of expression—the continuous traces of life flowing within this vessel. 
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 justify-between items-center">
          <h5 class="font-semibold text-black dark:text-white">
            Recent Posts
          </h5>
          <a href="/blog" class="whitespace-nowrap py-1 px-3 rounded-full border border-black/10 dark:border-white/25 hover:bg-black/5 dark:hover:bg-white/10 transition-colors text-xs">
            See all
          </a>
        </div>

        <p class="text-[11px] italic text-black/40 dark:text-white/40 -mt-3 tracking-wide">
          Note: Deep reflections and research notes are currently maintained in Chinese. 
          English translations are in progress...
        </p>

        <ul class="flex flex-col gap-4">
          {posts.map(post => (
            <li>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 justify-between items-center">
          <h5 class="font-semibold text-black dark:text-white">Life Tracks & Experiments</h5>
        </div>
        
        <div class="space-y-10">
          <div>
            <div class="text-xs text-black/50 dark:text-white/50">Jul 2024 - Mar 2026</div>
            <div class="font-semibold">Bioligo (Shanghai)</div>
            <div class="text-sm italic">Scientific Sales</div>
            <ul class="mt-2 list-disc list-inside text-sm space-y-1 text-black/70 dark:text-white/70">
              <li>Solo mission: Navigating universities, institutes, and hospitals to bridge research needs.</li>
              <li>Leveraging alumni networks and graduate background to foster deep-level trust with PIs and MDs.</li>
              <li>Acting as a multidisciplinary link between Business, R&D, and Logistics.</li>
              <li>Focusing on anti-fragility and self-driven growth within a flexible corporate structure.</li>
            </ul>
          </div>

          <div>
            <div class="text-xs text-black/50 dark:text-white/50">Nov 2025 - Feb 2026</div>
            <div class="font-semibold">Starbucks</div>
            <div class="text-sm italic">Barista</div>
            <p class="mt-2 text-sm text-black/70 dark:text-white/70">
              Shaking lattes, crafting Frappuccinos, and maintaining the flow of the store. Observing the relentless tide of people—a spiritual practice in the midst of everyday mundane tasks.
            </p>
          </div>

          <div>
            <div class="text-xs text-black/50 dark:text-white/50">Jun 2025 - Jun 2025</div>
            <div class="font-semibold">MCN Media Company</div>
            <div class="text-sm italic">Livestreamer</div>
            <p class="mt-2 text-sm text-black/70 dark:text-white/70">
              Stepping into the frame to witness how "influencers" are manufactured. Exploring the environment and the machinery behind the MCN industry while encountering diverse personas.
            </p>
          </div>

          <div>
            <div class="text-xs text-black/50 dark:text-white/50">Sep 2021 - Jul 2024</div>
            <div class="font-semibold">ECUST (East China University of Science and Technology)</div>
            <div class="text-sm italic">Graduate Student, School of Pharmacy</div>
            <ul class="mt-2 list-disc list-inside text-sm space-y-1 text-black/70 dark:text-white/70">
              <li>Research: Integration of CAR-T therapy and microfluidic chips.</li>
              <li>A stage of individual will versus systemic structures—refining personal identity within the domestic research framework.</li>
              <li>Recognized by mentors for "active thinking" and "maintaining a balance between original ideas and systemic survival."</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 justify-between items-center">
          <h5 class="font-semibold text-black dark:text-white">Inspired Works</h5>
          <a href="/projects" class="text-sm border-b border-black/20 dark:border-white/20">See all</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="border border-black/10 dark:border-white/10 p-4 rounded hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
            <div class="font-semibold">Astro Nano</div>
            <div class="text-xs text-black/50 italic">Minimal portfolio build.</div>
          </div>
          <div class="border border-black/10 dark:border-white/10 p-4 rounded hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
            <div class="font-semibold">Astro Sphere</div>
            <div class="text-xs text-black/50 italic">Portfolio and blog with Astro.</div>
          </div>
        </div>
      </section>

      <section class="animate space-y-4 pb-12">
        <h5 class="font-semibold text-black dark:text-white">Reach Out</h5>
        <p class="text-sm italic">"All things pass through, right here."</p>
        <div class="flex flex-wrap gap-3 text-sm">
          <a href="#" class="underline">Official Account</a>
          <span>/</span>
          <a href="#" class="underline">Podcast</a>
          <span>/</span>
          <a href="#" class="underline">Website</a>
          <span>/</span>
          <a href="mailto:rightheretc@163.com" class="underline">rightheretc@163.com</a>
        </div>
      </section>

    </div>
  </Container>
</PageLayout>
