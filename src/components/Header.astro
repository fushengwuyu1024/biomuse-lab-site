---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";
---

<header>
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between items-center">
      <Link href="/" underline={false}>
        <div class="font-semibold text-black dark:text-white text-lg tracking-tight">
          {SITE.NAME}
        </div>
      </Link>
      
      <nav class="flex gap-1 items-center text-sm font-serif">
        <Link href="/blog">文章</Link>
        <span class="text-black/30 dark:text-white/30">/</span>
        <Link href="/work">工作学习</Link>
        <span class="text-black/30 dark:text-white/30">/</span>
        <Link href="/projects">作品灵感</Link>

        <div class="mx-4 h-6 border-l border-black/15 dark:border-white/15"></div>

        <div class="flex flex-col items-center">
          <div class="flex gap-1 text-xs text-black/60 dark:text-white/60 font-medium">
            <Link href="/" underline={false}>CN</Link>
            <span>/</span>
            <Link href="/en" underline={false}>EN</Link>
            <span>/</span>
            <Link href="/de" underline={false}>DE</Link>
            <span>/</span>
            <Link href="/fr" underline={false}>FR</Link>
          </div>
          <span class="text-[10px] tracking-widest text-black/30 dark:text-white/30 pt-0.5 border-t border-black/10 dark:border-white/10 scale-90 w-full text-center mt-0.5">
            language
          </span>
        </div>
      </nav>
    </div>
  </Container>
</header>
