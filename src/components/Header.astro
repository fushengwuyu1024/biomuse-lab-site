---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";

// ✨ 核心逻辑：获取当前路径并判断语言
const url = Astro.url.pathname;
const isEn = url.includes('/en');
const isDe = url.includes('/de');
const isFr = url.includes('/fr');

// ✨ 根据语言定义导航文字
const nav = {
  blog: isEn ? "Blog" : isDe ? "Blog" : isFr ? "Blog" : "文章",
  work: isEn ? "Work" : isDe ? "Arbeit" : isFr ? "Expériences" : "工作学习",
  projects: isEn ? "Projects" : isDe ? "Projekte" : isFr ? "Projets" : "作品灵感",
  home: isEn ? "Home" : isDe ? "Home" : isFr ? "Accueil" : "就在此处"
};
---

<header>
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between items-center">
      <Link href="/" underline={false}>
        <div class="font-semibold text-black dark:text-white text-lg tracking-tight">
          {nav.home}
        </div>
      </Link>
      
      <nav class="flex gap-1 items-center text-sm">
        <Link href="/blog">{nav.blog}</Link>
        <span class="text-black/30 dark:text-white/30">/</span>
        <Link href="/work">{nav.work}</Link>
        <span class="text-black/30 dark:text-white/30">/</span>
        <Link href="/projects">{nav.projects}</Link>

        <div class="mx-4 h-6 border-l border-black/15 dark:border-white/15"></div>

        <div class="flex flex-col items-center">
          <div class="flex gap-1 text-xs text-black/60 dark:text-white/60 font-medium whitespace-nowrap">
            <Link href="/" underline={false}>CN</Link>
            <span>/</span>
            <Link href="/en" underline={false}>EN</Link>
            <span>/</span>
            <Link href="/de" underline={false}>DE</Link>
            <span>/</span>
            <Link href="/fr" underline={false}>FR</Link>
          </div>
          <span class="text-[10px] tracking-widest text-black/30 dark:text-white/30 mt-0.5 pt-0.5 border-t border-black/10 dark:border-white/10 scale-90 w-full text-center">
            language
          </span>
        </div>
      </nav>
    </div>
  </Container>
</header>
