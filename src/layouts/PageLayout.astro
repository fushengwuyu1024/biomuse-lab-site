---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { SITE } from "@consts";
import { ViewTransitions } from 'astro:transitions';

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={`${title} | ${SITE.NAME}`} description={description} />
    <ViewTransitions />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>

    <div id="music-container" style="position: fixed; bottom: 30px; right: 30px; z-index: 9999; cursor: pointer; display: flex; align-items: center; justify-content: center; width: 60px; height: 60px;">
      
      <div id="music-wrapper" style="position: relative; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
        
        <div id="music-core" style="position: absolute; width: 12px; height: 12px; background: #1a1a1a; border-radius: 50%; z-index: 3; transition: all 0.4s ease;"></div>

        <div id="music-galaxy" style="position: absolute; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; z-index: 2;">
          
          <div id="music-planet" style="position: absolute; width: 5px; height: 5px; background: #000; border-radius: 50%; top: -2px; opacity: 0; transition: opacity 0.3s ease;"></div>

          <div id="music-orbits" style="color: #000; opacity: 0.15; transform: scale(0.9); transition: all 0.3s ease;">
            <svg viewBox="0 0 24 24" width="50" height="50" stroke="currentColor" stroke-width="1.0" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <circle cx="12" cy="12" r="6.5"></circle>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </div>
        </div>
      </div>

      <audio id="bg-music" src="/audio/Opus55.mp3" loop transition:persist></audio>
    </div>

    <style is:global>
      /* 动画 A：星系圆周旋转 */
      @keyframes galaxy-rotation {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      /* 动画 B：深层呼吸脉动（缩放 + 透明度复合） */
      @keyframes deep-pulse {
        0%, 100% { transform: scale(0.88); opacity: 0.1; }
        50% { transform: scale(1.05); opacity: 0.45; }
      }

      /* 初始静止状态：轨道执行淡淡的呼吸，像在深海中闪烁 */
      #music-orbits {
        animation: deep-pulse 4s ease-in-out infinite;
      }

      /* 【播放激活状态】 */
      
      /* 1. 轨道层：开启旋转 + 增强呼吸感 */
      .playing #music-galaxy {
        animation: galaxy-rotation 5s linear infinite;
      }

      .playing #music-orbits {
        animation: deep-pulse 2.5s ease-in-out infinite !important; /* 播放时呼吸加快 */
        opacity: 0.8 !important;
        color: #000 !important;
      }

      /* 2. 星球浮现 */
      .playing #music-planet {
        opacity: 0.85 !important;
      }

      /* 3. 核心微调 */
      .playing #music-core {
        background: #000;
        transform: scale(1.1);
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
      }

      /* 鼠标悬停交互 */
      #music-container:hover #music-core {
        transform: scale(1.2);
        box-shadow: 0 0 15px rgba(0,0,0,0.15);
      }
    </style>

    <Footer />

    <script is:inline>
      function initBioMusePlayer() {
        const container = document.getElementById('music-container');
        const audio = document.getElementById('bg-music');
        
        if (!container || !audio) return;

        const syncUI = () => {
          if (!audio.paused) {
            container.classList.add('playing');
          } else {
            container.classList.remove('playing');
          }
        };

        // 跨页面自动接力状态
        syncUI();

        container.onclick = () => {
          if (audio.paused) {
            audio.play().then(syncUI).catch(e => console.log("Init blocked"));
          } else {
            audio.pause();
            syncUI();
          }
        };
      }

      // 响应 Astro 视图转换，确保跳转页面后逻辑依然存活
      document.addEventListener('astro:page-load', initBioMusePlayer);
    </script>
  </body>
</html>
