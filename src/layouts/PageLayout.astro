---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { SITE } from "@consts";
import { ViewTransitions } from 'astro:transitions';

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={`${title} | ${SITE.NAME}`} description={description} />
    <ViewTransitions />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>

    <div id="music-container" style="position: fixed; bottom: 30px; right: 30px; z-index: 9999; cursor: pointer; display: flex; align-items: center; justify-content: center; width: 50px; height: 50px;">
      
      <div id="music-core" style="position: absolute; width: 12px; height: 12px; background: #1a1a1a; border-radius: 50%; z-index: 2; transition: all 0.3s ease;"></div>

      <div id="music-disk" style="position: absolute; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; z-index: 1;">
        <div id="music-icon" style="color: #1a1a1a; opacity: 0.4; transition: all 0.3s ease;">
          <svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="6"></circle>
            <circle cx="12" cy="12" r="2"></circle>
          </svg>
        </div>
      </div>

      <audio id="bg-music" src="/audio/Opus55.mp3" loop transition:persist></audio>
    </div>

    <style is:global>
      /* 轨道公转动画 */
      @keyframes orbit-rotation {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      /* 初始呼吸状态（提示可点击） */
      @keyframes hint-breathe {
        0% { transform: scale(0.9); opacity: 0.3; }
        50% { transform: scale(1.1); opacity: 0.6; }
        100% { transform: scale(0.9); opacity: 0.3; }
      }

      /* 默认：同心圆轨道执行呼吸动画 */
      #music-icon {
        animation: hint-breathe 3s ease-in-out infinite;
      }

      /* 播放状态：切换到匀速旋转 */
      .playing-active #music-icon {
        animation: orbit-rotation 4s linear infinite !important;
        opacity: 0.9 !important;
        color: #000 !important; /* 播放时加深颜色，增强视觉感 */
      }

      /* 播放时中心黑点稍微放大，增加稳固感 */
      .playing-active #music-core {
        transform: scale(1.2);
        background: #000;
      }

      /* 悬停时的小反馈 */
      #music-container:hover #music-core {
        box-shadow: 0 0 10px rgba(0,0,0,0.2);
      }
    </style>

    <Footer />

    <script is:inline>
      function initGalaxyPlayer() {
        const container = document.getElementById('music-container');
        const audio = document.getElementById('bg-music');
        
        if (!container || !audio) return;

        const syncState = () => {
          if (!audio.paused) {
            container.classList.add('playing-active');
          } else {
            container.classList.remove('playing-active');
          }
        };

        // 页面跳转后的状态接力
        syncState();

        container.onclick = () => {
          if (audio.paused) {
            audio.play().then(syncState).catch(err => console.log("Playback blocked"));
          } else {
            audio.pause();
            syncState();
          }
        };
      }

      // 配合 ViewTransitions 的生命周期
      document.addEventListener('astro:page-load', initGalaxyPlayer);
    </script>
  </body>
</html>
